	<sub-flow name="sysAPI-DB-Subflow" doc:id="60b41fc0-f7bc-42f0-a1ef-0d208549187f" >
		<db:bulk-insert doc:name="Bulk insert" doc:id="85c94513-1c4b-4007-a4ca-63d0c13579c2" config-ref="Database_Config">
			<db:sql ><![CDATA[INSERT INTO Accounts (sf_id, account_name, location, phone_number) 
        VALUES (:sf_id, :account_name, :location, :phone_number)
        ON DUPLICATE KEY UPDATE 
        account_name = VALUES(account_name),
        phone_number = VALUES(phone_number),
        location = VALUES(location)]]></db:sql>
		</db:bulk-insert>
		<ee:transform doc:name="Transform Message" doc:id="d8c32bc6-305d-482a-a368-bc90865be462" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
	"Message": "Data Sucessfully Inserted/Updated"
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</sub-flow>
