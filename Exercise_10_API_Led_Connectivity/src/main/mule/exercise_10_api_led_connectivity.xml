	<flow name="expAPI-account-managment-flow" doc:id="7a163c9c-b99f-4454-9ec4-e4e549fdc236" >
		<http:listener doc:name="Listener" doc:id="4b7311c1-d614-4d29-976c-fc5f070a933d" config-ref="HTTP_Listener_config" path="/accounts"/>
		<ee:transform doc:name="Transform Message" doc:id="841662c1-f7cd-46b6-8b37-13fc371f19ef" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<flow-ref doc:name="Flow Reference" doc:id="3238cdaf-7ebf-4dbc-baf2-5213ef2ec466" name="proAPI-account-logic-subflow"/>
	</flow>
	<sub-flow name="proAPI-account-logic-subflow" doc:id="d123e90c-f3f6-4d7a-a839-c241f4f14bcc" >
		<flow-ref doc:name="Flow Reference" doc:id="a75c5e42-79a2-40b8-8efa-badf2a49c297" name="sysAPI-sf-query-subflow"/>
		<choice doc:name="Choice" doc:id="15a39aac-95bb-43d6-acdf-e895167718ca" >
			<when expression="#[sizeOf(payload) &gt; 0]">
				<flow-ref doc:name="Flow Reference" doc:id="ca5954dc-2f43-46ff-9976-a12f9a5f259b" name="sysAPI-DB-Subflow"/>
			</when>
			<otherwise>
				<logger level="INFO" doc:name="Logger" doc:id="365c104d-b992-493a-bc3d-59420eee8215" message="There isn't any Accounts in Salesforce."/>
			</otherwise>
		</choice>
	</sub-flow>
	<sub-flow name="sysAPI-sf-query-subflow" doc:id="72ea43a0-a81f-4ae7-94ff-cdb902eae39f" >
		<salesforce:query doc:name="Query" doc:id="e473e537-38fc-40ae-961d-2f80cdd1f01b" config-ref="Salesforce_Config">
			<salesforce:salesforce-query ><![CDATA[#[payload.query]]]></salesforce:salesforce-query>
		</salesforce:query>
		<ee:transform doc:name="Transform Message" doc:id="3c4b67df-aa35-487e-a607-01d2e52ba143" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload map (item) -> {
    account_name: item.Name,
    location: item.BillingCity default "N/A",
    phone_number: item.Phone default "No Phone",
    sf_id: item.Id
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</sub-flow>
